          }
        }
      }
    },
    "/pages/{id}/rollback": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "security": [
          {
            "cookieSession": []
          }
        ],
        "parameters": [
          {
            "name": "X-CSRF-Token",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Current CSRF value returned by GET /me."
          }
        ],
        "summary": "Rollback page",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "targetRevisionId": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "reason": {
                    "type": "string",
                    "maxLength": 1000,
                    "default": ""
                  }
                },
                "required": ["targetRevisionId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rollback revision"
          }
        }
      }
    },
    "/search": {
      "get": {
        "summary": "Search pages",
        "responses": {
          "200": {
            "description": "Results"
          }
        }
      }
    },
    "/categories": {
      "get": {
        "summary": "List categories",
        "responses": {
          "200": {
            "description": "Categories"
          }
        }
      }
    },
    "/categories/{slug}": {
      "get": {
        "summary": "Get category",
        "responses": {
          "200": {
            "description": "Category"
          }
        }
      }
    },
    "/media": {
      "get": {
        "summary": "List media",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Media"
          }
        }
      },
      "post": {
        "security": [
          {
            "cookieSession": []
          }
        ],
        "parameters": [
          {
            "name": "X-CSRF-Token",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Current CSRF value returned by GET /me."
          }
        ],
        "summary": "Upload media",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "altText": {
                    "type": "string",
                    "maxLength": 2000
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Uploaded"
          }
        }
      }
    },
    "/media/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "summary": "List content references to a media asset",
        "responses": {
          "200": {
            "description": "Media references"
          }
        }
      },
      "delete": {
        "security": [
          {
            "cookieSession": []
          }
        ],
        "parameters": [
          {
            "name": "X-CSRF-Token",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Current CSRF value returned by GET /me."
          },
          {
            "name": "force",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Delete even when content references are present."
          }
        ],
        "summary": "Delete media",
        "responses": {
          "204": {
            "description": "Deleted"
          }
        }
      }
    },
    "/me": {
      "get": {
        "summary": "Current user",
        "responses": {
          "200": {
            "description": "User"
          }
        }
      }
    },
    "/admin/users": {
      "get": {
        "security": [
          {
            "cookieSession": []
          }
        ],
        "summary": "List users",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Users"
