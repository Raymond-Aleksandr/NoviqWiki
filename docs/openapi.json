        ],
        "summary": "Update user group memberships",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "groupIds": {
                    "type": "array",
                    "maxItems": 100,
                    "default": [],
                    "items": {
                      "type": "string",
                      "format": "uuid"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User groups"
          }
        }
      }
    },
