                        "user.manage",
                        "group.read",
                        "group.manage",
                        "role.read",
                        "role.manage",
                        "audit.read",
                        "backup.create"
                      ]
                    },
                    "default": []
                  }
                },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Role"
