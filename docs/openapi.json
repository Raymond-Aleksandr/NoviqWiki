        }
      }
    },
    "/revisions/{from}/diff/{to}": {
      "parameters": [
        {
          "name": "from",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "to",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "summary": "Compare revisions",
        "responses": {
          "200": {
